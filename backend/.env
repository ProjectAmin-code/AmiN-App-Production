APP_NAME=AmiN Sync API
APP_ENV=development
APP_DEBUG=true
API_PREFIX=/api

DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/amin_sync

JWT_SECRET_KEY=change_me_to_a_secure_random_string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

MOBILE_RATE_LIMIT_PER_MINUTE=120
LEGACY_PROGRESS_COMPAT=true
